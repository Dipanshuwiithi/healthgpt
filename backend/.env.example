# Get your free Gemini API key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# PostgreSQL connection string. Leave unset for local development —
# the app will automatically fall back to a local SQLite file
# (backend/healthgpt.db) when DATABASE_URL is not provided.
# In production (e.g. Render), this is set automatically when you
# attach a Postgres database to the service.
# DATABASE_URL=postgresql://user:password@host:5432/dbname
